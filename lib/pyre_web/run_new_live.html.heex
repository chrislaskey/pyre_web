<.page_layout
  current_page={:new_run}
  prefix={pyre_path(@socket, "")}
  uri={@uri}
  breadcrumbs={[
    %{label: "Runs", path: pyre_path(@socket, "/runs")},
    %{label: "New Run"}
  ]}
>
  <div class="mb-6">
    <.h1>New Run</.h1>
  </div>

  <.flash_group flash={@flash} />

  <form phx-submit="submit" phx-change="validate" class="mb-6">
    <div class="mb-8 p-6 border border-base-300 bg-primary-200/80 rounded-xl">
      <label class="label mb-2">
        <span class="label-text">Prompt</span>
      </label>
      <textarea
        name="run[feature_description]"
        class="textarea textarea-bordered w-full h-32 text-sm"
        placeholder="Build a products listing page with search and pagination..."
      >{Phoenix.HTML.Form.input_value(@form, :feature_description)}</textarea>

      <div id="attachment-upload" phx-hook="PasteUpload" class="mt-3 mb-6">
        <.live_file_input upload={@uploads.attachments} class="hidden" />

        <div
          :for={entry <- @uploads.attachments.entries}
          class="flex items-center gap-3 p-3 border border-base-300 rounded-lg bg-base-200/50 mb-2"
        >
          <.live_img_preview
            :if={String.starts_with?(entry.client_type, "image/")}
            entry={entry}
            class="max-h-24 rounded border border-base-300"
          />
          <div
            :if={not String.starts_with?(entry.client_type, "image/")}
            class="flex items-center justify-center w-10 h-10 rounded border border-base-300 bg-base-200 text-base-content/40 text-xs font-mono shrink-0"
          >
            {entry.client_name |> Path.extname() |> String.trim_leading(".")}
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-sm text-base-content/70">{entry.client_name}</span>
            <button
              type="button"
              phx-click="cancel-upload"
              phx-value-ref={entry.ref}
              class="btn btn-ghost btn-xs w-fit"
            >
              Remove
            </button>
          </div>
          <p
            :for={err <- upload_errors(@uploads.attachments, entry)}
            class="text-error text-sm"
          >
            {upload_error_to_string(err)}
          </p>
        </div>

        <div
          phx-drop-target={@uploads.attachments.ref}
          class="border-1 border-base-300 bg-base-200 rounded-lg p-4 text-center text-sm text-base-content/50"
        >
          Paste or drop a file, or
          <label class="link cursor-pointer" for={@uploads.attachments.ref}>
            browse
          </label>
        </div>

        <p
          :for={err <- upload_errors(@uploads.attachments)}
          class="text-error text-sm mt-1"
        >
          {upload_error_to_string(err)}
        </p>
      </div>

      <div>
        <label class="label mb-2">
          <span class="label-text">Project</span>
          <span class="label-text-alt text-base-content/30">Optional</span>
        </label>
        <input
          type="text"
          name="run[feature_name]"
          value={@feature_name}
          list="feature-suggestions"
          placeholder="e.g. products-page"
          class="input input-bordered w-full font-mono text-sm"
        />
        <datalist id="feature-suggestions">
          <option :for={name <- @feature_suggestions} value={name} />
        </datalist>
      </div>
    </div>

    <div class="mb-8">
      <label class="label mb-2">
        <span class="label-text">Workflow</span>
      </label>
      <div class="flex gap-4">
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="chat"
            checked={@workflow == :chat}
            phx-click="select_workflow"
            phx-value-workflow="chat"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Chat</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="feature"
            checked={@workflow == :feature}
            phx-click="select_workflow"
            phx-value-workflow="feature"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Feature</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="prototype"
            checked={@workflow == :prototype}
            phx-click="select_workflow"
            phx-value-workflow="prototype"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Prototype</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="task"
            checked={@workflow == :task}
            phx-click="select_workflow"
            phx-value-workflow="task"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Task</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="code_review"
            checked={@workflow == :code_review}
            phx-click="select_workflow"
            phx-value-workflow="code_review"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Code Review</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="workflow"
            value="overnight_feature"
            checked={@workflow == :overnight_feature}
            phx-click="select_workflow"
            phx-value-workflow="overnight_feature"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Overnight Feature</span>
        </label>
      </div>
    </div>

    <div class="mb-8">
      <label class="label mb-2">
        <span class="label-text">LLM Backend</span>
      </label>
      <div class="flex gap-4">
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="llm_backend"
            value="claude_cli"
            checked={@llm_backend == :claude_cli}
            phx-click="select_backend"
            phx-value-backend="claude_cli"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Claude CLI</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="llm_backend"
            value="cursor_cli"
            checked={@llm_backend == :cursor_cli}
            phx-click="select_backend"
            phx-value-backend="cursor_cli"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Cursor CLI</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="llm_backend"
            value="codex_cli"
            checked={@llm_backend == :codex_cli}
            phx-click="select_backend"
            phx-value-backend="codex_cli"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">Codex CLI</span>
        </label>
        <label class="label cursor-pointer justify-start gap-2">
          <input
            type="radio"
            name="llm_backend"
            value="req_llm"
            checked={@llm_backend == :req_llm}
            phx-click="select_backend"
            phx-value-backend="req_llm"
            class="radio radio-sm radio-primary"
          />
          <span class="label-text">API (ReqLLM)</span>
        </label>
      </div>
      <p class="text-xs text-base-content/70 mt-1">
        API uses ReqLLM with per-token billing. Claude CLI uses the local <code>claude</code>
        command (free with Pro/Max subscription). Cursor CLI uses the local
        <code>cursor-agent</code>
        command (free with Cursor subscription, supports multiple models). Codex CLI uses the local
        <code>codex</code>
        command (requires ChatGPT Plus/Pro or OpenAI API key).
      </p>
    </div>

    <div class="mb-8">
      <label class="label mb-2">
        <span class="label-text">Workflow Stages</span>
      </label>
      <p class="text-sm text-base-content/50 mb-2">
        Uncheck stages to skip them. Enable interactive to pause after each stage for feedback.
      </p>
      <div class="flex flex-col gap-2">
        <div
          :for={{stage_key, label} <- @toggleable_stages}
          class="flex items-center gap-3"
        >
          <input
            type="checkbox"
            checked={stage_key not in @skipped_stages}
            phx-click="toggle_stage"
            phx-value-stage={stage_key}
            class="toggle toggle-sm toggle-primary"
          />
          <span class="text-sm flex-1">{label}</span>
          <label class="flex items-center gap-1 cursor-pointer">
            <span class="text-xs text-base-content/40">interactive</span>
            <input
              type="checkbox"
              checked={stage_key in @interactive_stages}
              phx-click="toggle_interactive_stage"
              phx-value-stage={stage_key}
              class="toggle toggle-sm toggle-secondary"
            />
          </label>
        </div>
      </div>
    </div>

    <button type="submit" class="btn btn-primary">
      Run Pipeline
    </button>
  </form>
</.page_layout>
